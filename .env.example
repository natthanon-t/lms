# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=cbt_lms
POSTGRES_PORT=5432
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=CHANGE_ME_strong_password_here
PGADMIN_PORT=5050
PGADMIN_SERVER_NAME=CBT Postgres
PGADMIN_DB_HOST=postgres
PGADMIN_DB_PORT=5432
PGADMIN_DB_NAME=cbt_lms
PGADMIN_DB_USER=postgres
PGADMIN_DB_PASSWORD=CHANGE_ME_strong_password_here

# API
API_PORT=5020
# sslmode=require is recommended in production
DATABASE_URL=postgres://postgres:CHANGE_ME_strong_password_here@postgres:5432/cbt_lms?sslmode=disable
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_HOURS=168
CORS_ORIGINS=http://localhost:5173
APP_ADMIN_NAME=System Admin
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=CHANGE_ME_strong_password_here

# Frontend
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:5020
